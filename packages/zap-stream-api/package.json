{
  "name": "@zap.stream/api",
  "version": "0.1.0",
  "description": "zap.stream API client — live streaming & account management for Nostr",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target browser --format esm --sourcemap=linked --packages external && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@scure/base": "^2.2.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/v0l/zap.stream.git",
    "directory": "packages/zap-stream-api"
  },
  "keywords": [
    "nostr",
    "zap-stream",
    "live-streaming",
    "api-client"
  ]
}
